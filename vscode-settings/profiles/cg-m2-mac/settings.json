{
  // workbench
  "workbench.activityBar.orientation": "vertical",
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.wrapTabs": false,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Dark Modern",
  // explorer
  "explorer.confirmDragAndDrop": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  // window
  "window.zoomLevel": -1.5,
  "window.commandCenter": true,
  "cSpell.userWords": [
    "afplay",
    "Agones",
    "akasha",
    "anthropics",
    "apcu",
    "asyncio",
    "autoremove",
    "BDOT",
    "BDOTDIR",
    "bgmdb",
    "buildx",
    "CCOEFF",
    "CEDEC",
    "certifi",
    "Chara",
    "chdir",
    "Classful",
    "cloudshell",
    "cooldown",
    "CROSSSLOT",
    "Cygames",
    "datapoints",
    "dockercompose",
    "DOTENV",
    "dotenvx",
    "DOTPATH",
    "ecpu",
    "Eeuo",
    "elasticloadbalancingv",
    "elbv",
    "elif",
    "endraw",
    "entra",
    "esac",
    "Espacenet",
    "Fargate",
    "fdfind",
    "getenv",
    "getline",
    "gitdir",
    "grayscale",
    "healthcheck",
    "httpx",
    "Intelephense",
    "isort",
    "JASRAC",
    "keepalive",
    "Koebon",
    "laravel",
    "libpq",
    "meilisearch",
    "Mkdocs",
    "mktemp",
    "MSYS",
    "musicdb",
    "mypy",
    "mysqli",
    "mysqlnd",
    "NAPT",
    "netskope",
    "nohup",
    "nscacert",
    "numpy",
    "numstat",
    "Pathlib",
    "PDCA",
    "pecl",
    "pgvector",
    "phpbench",
    "phpcbf",
    "phpcs",
    "phpdoc",
    "phpredis",
    "phpstan",
    "phpunit",
    "pinact",
    "pipefail",
    "PITR",
    "pkce",
    "predis",
    "Pydantic",
    "pynput",
    "pyproject",
    "pyright",
    "pytesseract",
    "pytest",
    "PYTHONPATH",
    "PYTHONUNBUFFERED",
    "Qiita",
    "readlink",
    "realpath",
    "rybakit",
    "SCRIPTDIR",
    "Sercuit",
    "shellcheck",
    "shfmt",
    "signingkey",
    "songdb",
    "starlette",
    "subissue",
    "subissues",
    "Tesseract",
    "trunc",
    "Tsumiki",
    "typer",
    "Umatoria",
    "unpushed",
    "USPTO",
    "uvicorn",
    "Valkey",
    "VARCHAR",
    "venv",
    "wada",
    "winget",
    "worktree"
  ],
  "terminal.integrated.enableBracketedPasteMode": false,
  "editor.formatOnSave": false,
  "trailing-spaces.trimOnSave": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "text": "日本語で書く。" },
    { "text": "Subject は50文字以内（全角約25文字目安）に収める。" },
    {
      "text": "NEVER use Conventional Commits prefixes. Do NOT start with feat:, fix:, docs:, chore:, refactor:, etc."
    },
    { "text": "gitmoji や絵文字は使わない。" },
    {
      "text": "変更内容を直接記述する。日本語の場合は動詞で終える: 「〜を追加、〜を修正、〜に変更、〜を削除」など"
    },
    {
      "text": "コード参照（クラス名・設定キー・ファイル名等）はバッククォートで囲む。"
    },
    { "text": "Subject の末尾にピリオド（。）を付けない。" },
    {
      "text": "Body は変更の理由や背景を説明する。ただし、Subjectだけで十分な場合は省略する。"
    },
    { "text": "Subject と Body は空行で分離する。" },
    {
      "text": "Body の箇条書きは - を使う。what と why を説明し、how は書かない。最大でも72文字になるように端的に書く。"
    },
    {
      "text": "良い Subject の例: `Config\\Database` のリトライポリシー適用漏れを修正 / PHP標準Exception使用箇所を `ExceptionBase` に変更"
    }
  ],
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "markdownlint.run": "onSave",
  "markdownlint.config": {
    "default": true,
    "MD010": {
      "code_blocks": false
    },
    "MD014": false,
    "MD024": false,
    "MD033": false,
    "MD036": false
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.formatOnSave": true
  },
  "database-client.autoSync": true,
  "sqlfluff.dialect": "mysql",
  "sqlfluff.linter.run": "onSave",
  "sqlfluff.format.enabled": true,
  "[sql]": {
    "editor.defaultFormatter": "dorzey.vscode-sqlfluff",
    "editor.formatOnSave": true
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "editor.formatOnSave": true
  },
  "[jsonl]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "editor.formatOnSave": true
  },
  /**
   * @description jsonc 用の設定
   * esbenp.prettier-vscode が jsonc において、勝手に trailingComma を追加してしまう問題がある
   * そこで、jsonc では以下の項目によって本ファイルの設定を prettier に使わせるように強制する
   */
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "prettier.useEditorConfig": false // プロジェクトに .editorconfig があっても無視する
  },
  "prettier.requireConfig": false, // プロジェクトに .prettierrc がなくても動作させる
  // ↑ jsonc の問題対応はここまで
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[yml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "git.blame.statusBarItem.enabled": false,
  "files.watcherExclude": {
    "": true
  },
  "files.exclude": {
    "**/.git": false
  },
  "intelephense.stubs": ["redis", "standard", "pcre", "date"],
  "intelephense.environment.includePaths": ["vendor/jetbrains/phpstorm-stubs"],
  "git.suggestSmartCommit": false,
  "files.associations": {
    "*.md": "markdown",
    "*.yml": "yaml"
  },
  // テキスト校正くん
  "japanese-proofreading.textlint.ひらく漢字": false,
  "japanese-proofreading.textlint.外来語カタカナ表記": false,
  "japanese-proofreading.textlint.全角文字と半角文字の間": false,
  "japanese-proofreading.textlint.丸かっこ（）": false,
  "japanese-proofreading.textlint.助詞の連続": false,
  "japanese-proofreading.textlint.技術用語": false,
  "vsicons.dontShowNewVersionMessage": true,
  "gitlens.views.commits.files.layout": "tree",
  "makefile.configureOnOpen": true,
  "remote.autoForwardPortsSource": "hybrid",
  "cursor.cpp.disabledLanguages": ["plaintext", "scminput"],
  "git-worktree-manager.worktreeCopyPatterns": ["CLAUDE.md", ".claude/"],
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  // dotfiles 設定: DecContainer で自動的に dotfiles をクローンしてインストールする
  "dotfiles.repository": "https://github.com/Seika139/dotfiles.git", // dotfiles リポジトリの URL を指定
  "dotfiles.installCommand": "install.sh", // インストールコマンドを指定
  "terminal.integrated.profiles.linux": {
    // Linux でターミナルを開くときに bash を login シェルで開く設定
    // Docker コンテナがデフォルトで非ログインシェルで開かれるのを回避する
    "bash": { "path": "bash", "icon": "terminal-bash", "args": ["-l"] }
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "remote.containers.environment": {
    "GIT_USER_NAME": "${localEnv:GIT_USER_NAME}",
    "GIT_USER_SIGNINGKEY": "${localEnv:GIT_USER_SIGNINGKEY}",
    "GIT_USER_EMAIL": "${localEnv:GIT_USER_EMAIL}"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "python.terminal.activateEnvironment": false,
  "cursor.general.disableHttp2": true,
  "cursor.general.disableHttp1SSE": true
}
