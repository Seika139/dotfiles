    "errexit",
    "errtrace",
    "esac",
    "esbenp",
    "fallocate",
    "fdfind",
    "Fernet",
    "ffprobe",
    "frontmatter",
    "FUNCTAB",
    "futaba",
    "genai",
    "getline",
    "gitattributes",
    "gitdir",
    "gmail",
    "GOPATH",
    "grayscale",
    "gsed",
    "gtts",
    "healthcheck",
    "HISTSIZE",
    "imgur",
    "Inno",
    "insta",
    "instagrams",
    "isort",
    "isucon",
    "keepalive",
    "Laravel",
    "letsencrypt",
    "LTSV",
    "manabi",
    "manabitimes",
    "marp",
    "Mathf",
    "mktemp",
    "moltbot",
    "mshta",
    "msys",
    "mypy",
    "mysqldump",
    "ndarray",
    "Neconome",
    "ngrok",
    "nounset",
    "nsscreen",
    "numpy",
    "numstat",
    "OOTD",
    "openclaw",
    "opendiff",
    "pacman",
    "pathlib",
    "phpunit",
    "pipefail",
    "pipx",
    "pixabay",
    "previewable",
    "printf",
    "Println",
    "protocolbuffers",
    "psql",
    "pwsh",
    "pyautogui",
    "pycache",
    "pycromanager",
    "pycryptodomex",
    "Pydantic",
    "pydocstyle",
    "pyenv",
    "pynput",
    "pyplot",
    "pyproject",
    "pytesseract",
    "pytest",
    "PYTHONPATH",
    "PYTHONUNBUFFERED",
    "pytz",
    "Qiita",
    "Quali",
    "readlink",
    "readwrite",
    "realpath",
    "redash",
    "reflog",
    "repost",
    "reposting",
    "SAPI",
    "SCRIPTDIR",
    "Seika",
    "setw",
    "sfnv",
    "shellcheck",
    "shellenv",
    "shfmt",
    "signingkey",
    "smallint",
    "strcpy",
    "struct",
    "subissue",
    "subissues",
    "suzukikenichi",
    "swapfile",
    "swapon",
    "sysstat",
    "tada",
    "teratail",
    "termius",
    "Tesseract",
    "textlint",
    "timesheet",
    "timesheets",
    "tinyint",
    "tmpfs",
    "toset",
    "trunc",
    "Tweening",
    "UGUI",
    "unalias",
    "Unicursal",
    "Unipack",
    "untap",
    "usermod",
    "USERPROFILE",
    "VARCHAR",
    "vbscript",
    "venv",
    "Vixengo",
    "vuetify",
    "webroot",
    "winget",
    "worktree",
    "wslpath"
  ],
  "[html]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
  },
  "files.exclude": {
    "**/.git": false,
    "**/*.meta": true,
    "**/*.out": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true
  },
  // テキスト校正くん
  "japanese-proofreading.textlint.丸かっこ（）": false,
  "japanese-proofreading.textlint.全角文字と半角文字の間": false,
  "japanese-proofreading.textlint.外来語カタカナ表記": false,
  "japanese-proofreading.textlint.ひらく漢字": false,
  "japanese-proofreading.textlint.助詞の連続": false,
  "japanese-proofreading.textlint.技術用語": false,
  // yaml
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "keep",
    "gitlens.codeLens.scopes": ["document"],
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    }
  },
  // docker-compose.yml
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "keep",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "markdown.marp.themes": [
    "/Users/suzukikenichi/knowledges/reading_books/test.css"
  ],
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "redhat.telemetry.enabled": true,
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "shellcheck.customArgs": ["-x"],
  "terminal.integrated.profiles.osx": {
    "bash": {
      "path": "bash",
      "args": ["-l"],
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "zsh",
      "args": ["-l"]
    },
    "fish": {
      "path": "fish",
      "args": ["-l"]
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    },
    "dash": {
      "path": "/bin/dash"
    }
  },
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.unicodeVersion": "11",
  "vsicons.dontShowNewVersionMessage": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[csharp]": {
    "editor.formatOnSave": true
  },
  "omnisharp.path": "latest",
  "omnisharp.monoPath": "/Library/Frameworks/Mono.framework/Versions/Current/Commands/mono",
  "omnisharp.useGlobalMono": "always",
  "omnisharp.useModernNet": false,
  "editor.formatOnPaste": true,
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "security.workspace.trust.untrustedFiles": "open",
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "scminput": true,
    "plaintext": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "text": "日本語で書く。" },
    { "text": "Subject は50文字以内（全角約25文字目安）に収める。" },
    {
      "text": "NEVER use Conventional Commits prefixes. Do NOT start with feat:, fix:, docs:, chore:, refactor:, etc."
    },
    { "text": "gitmoji や絵文字は使わない。" },
    {
      "text": "変更内容を直接記述する。日本語の場合は動詞で終える: 「〜を追加、〜を修正、〜に変更、〜を削除」など"
    },
    {
      "text": "コード参照（クラス名・設定キー・ファイル名等）はバッククォートで囲む。"
    },
    { "text": "Subject の末尾にピリオド（。）を付けない。" },
    {
      "text": "Body は変更の理由や背景を説明する。ただし、Subjectだけで十分な場合は省略する。"
    },
    { "text": "Subject と Body は空行で分離する。" },
    {
      "text": "Body の箇条書きは - を使う。what と why を説明し、how は書かない。最大でも72文字になるように端的に書く。"
    },
    {
      "text": "良い Subject の例: `Config\\Database` のリトライポリシー適用漏れを修正 / PHP標準Exception使用箇所を `ExceptionBase` に変更"
    }
  ],
  "accessibility.signals.onDebugBreak": {
    "announcement": "off",
    "sound": "off"
  },
  "accessibility.signals.noInlayHints": {
    "announcement": "off",
    "sound": "off"
  },
  "accessibility.signals.chatResponseReceived": {
    "sound": "off"
  },
  "accessibility.signals.taskFailed": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signalOptions.volume": 0,
  "makefile.configureOnOpen": true,
  "python.analysis.typeCheckingMode": "standard",
  "window.zoomLevel": -0.8,
  "terminal.integrated.detectLocale": "auto",
  "docker.extension.enableComposeLanguageServer": false,
  "diffEditor.codeLens": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4",
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "geminicodeassist.displayInlineContextHint": false,
  "remote.autoForwardPortsSource": "hybrid",
  "python.languageServer": "Default",
  "color-picker-universal.avoidDuplicate": true,
  // dotfiles 設定: DecContainer で自動的に dotfiles をクローンしてインストールする
  "dotfiles.repository": "https://github.com/Seika139/dotfiles.git", // dotfiles リポジトリの URL を指定
  "dotfiles.installCommand": "install.sh", // インストールコマンドを指定
  "terminal.integrated.profiles.linux": {
    // Linux でターミナルを開くときに bash を login シェルで開く設定
    // Docker コンテナがデフォルトで非ログインシェルで開かれるのを回避する
    "bash": { "path": "bash", "icon": "terminal-bash", "args": ["-l"] }
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "remote.containers.environment": {
    "GIT_USER_NAME": "${localEnv:GIT_USER_NAME}",
    "GIT_USER_SIGNINGKEY": "${localEnv:GIT_USER_SIGNINGKEY}",
    "GIT_USER_EMAIL": "${localEnv:GIT_USER_EMAIL}"
  },
  "terraform.languageServer.enable": true,
  "agq.pinnedModels": ["MODEL_PLACEHOLDER_M37"]
}
