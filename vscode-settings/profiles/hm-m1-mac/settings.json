{
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "all",
  "editor.accessibilitySupport": "on",
  "editor.acceptSuggestionOnEnter": "off", // エンターキーでの補完を無効にする
  "editor.rulers": [40, 80, 88, 120, 160, 200], // 垂直ルーラーの表示
  // workbench
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.wrapTabs": false,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Dark Modern",
  // explorer
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.openEditors.sortOrder": "alphabetical",
  // git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.suggestSmartCommit": false,
  // python
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "black-formatter.args": ["--line-length=88"],
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "python.terminal.activateEnvironment": false,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "editor.formatOnSave": true
  },
  "[jsonl]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "editor.formatOnSave": true
  },
  /**
   * @description jsonc 用の設定
   * esbenp.prettier-vscode が jsonc において、勝手に trailingComma を追加してしまう問題がある
   * そこで、jsonc では以下の項目によって本ファイルの設定を prettier に使わせるように強制する
   */
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "prettier.endOfLine": "lf",
    "prettier.trailingComma": "none",
    "prettier.useEditorConfig": false // プロジェクトに .editorconfig があっても無視する
  },
  "prettier.requireConfig": false, // プロジェクトに .prettierrc がなくても動作させる
  // ↑ jsonc の問題対応はここまで
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdown-pdf.styles": [
    "~/pro-main/vscode-help/src/markdown/markdown-pdf.css"
  ],
  "markdown-pdf.displayHeaderFooter": false,
  "todohighlight.keywords": [
    {
      "text": "TODO :",
      "color": "red",
      "border": "1px solid red",
      "borderRadius": "2px", //NOTE: using borderRadius along with `border` or you will see nothing change
      "backgroundColor": "rgba(0,0,0,.2)"
    },
    {
      "text": "NOTE :",
      "color": "#fff",
      "backgroundColor": "#4c26"
    }
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "tabnine.experimentalAutoImports": true,
  "files.insertFinalNewline": true, // 最終行は改行にする
  // code-runner : https://murabitoleg.com/vscode-runner/
  // "code-runner.clearPreviousOutput": true,
  "code-runner.runInTerminal": true,
  // 言語認識の関連付け
  "files.associations": {
    "*.txt": "Markdown",
    "*.jslib": "javascript",
    "*.conf": "nginx",
    "nginx.conf": "nginx",
    "*.jsonc": "jsonc"
  },
  // emmet
  "emmet.variables": {
    "lang": "ja"
  },
  "emmet.includeLanguages": {
    "vue-html": "html"
  },
  "emmet.triggerExpansionOnTab": true, // これをオンにしないと ctrl + e が効かない
  "cSpell.userWords": [
    "Abema",
    "adduser",
    "afplay",
    "anthropics",
    "Anzu",
    "arange",
    "asorti",
    "astype",
    "autoremove",
    "awsp",
    "bashenv",
    "batcat",
    "BDOT",
    "BDOTDIR",
    "Behaviour",
    "Brotli",
    "buildx",
