{
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "ANTHROPIC_MODEL": "global.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_SMALL_FAST_MODEL": "us.anthropic.claude-haiku-4-5-20251001-v1:0",
    "API_TIMEOUT_MS": "1200000",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "530000",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "MAX_THINKING_TOKENS": "1024"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "pwsh.exe -c \"New-BurntToastNotification -Text '🦄 Claude Code', \\\"実行中の claude が停止しました.`n$env:USERNAME@$env:COMPUTERNAME $(Get-Location)\\\"\"",
            "type": "command"
          },
          {
            "command": "sleep 9.7 && mshta vbscript:Execute(\"CreateObject(\"\"SAPI.SpVoice\"\").Speak(\"\"クロードが停止しました\"\"):close\")",
            "type": "command"
          },
          {
            "command": "pwsh -sta -c \"Add-Type -AssemblyName presentationCore; $homePath=[Environment]::GetFolderPath('UserProfile'); $dir=Join-Path $homePath 'dotfiles\\claude\\ringtones'; $files=Get-ChildItem -LiteralPath $dir -File | Where-Object { $_.Extension -match '^\\.(mp3|wav)' }; if($files){ $pick=$files | Get-Random; $m=New-Object System.Windows.Media.MediaPlayer; $m.Volume = 0.4; $m.Open([uri]$pick.FullName); $m.Play(); Start-Sleep 10 } else { [console]::Beep(880,300) }\"",
            "type": "command"
          },
          {
            "command": "~/dotfiles/claude/notify_slack.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(gh auth status)",
      "Bash(gh extension list)",
      "Bash(gh run list)",
      "Bash(gh run view:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(New-Item:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(powershell:*)",
      "Command(curl:*)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(.env)",
      "Read(**/*token*)",
      "Read(**/secrets/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(cdk deploy:*)",
      "Bash(git reset:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh alias set:*)",
      "Bash(gh alias delete:*)",
      "Bash(gh api POST:*)",
      "Bash(gh api PUT:*)",
      "Bash(gh api PATCH:*)",
      "Bash(gh api DELETE:*)"
    ]
  },
  "statusLine": {
    "command": "~/dotfiles/claude/status_line.sh",
    "type": "command"
  }
}
