{
  "permissions": {
    "permissions": {
      "allow": [
        "Bash(mkdir:*)",
        "Bash(touch:*)",
        "Bash(ls:*)",
        "Bash(cat:*)",
        "Bash(gh auth status)",
        "Bash(gh extension list)",
        "Bash(gh run list)",
        "Bash(gh run view:*)"
      ],
      "deny": [
        "Bash(sudo:*)",
        "Bash(rm -rf:*)",
        "Read(.env)",
        "Read(**/*token*)",
        "Read(**/secrets/**)",
        "Read(**/*_key)",
        "Read(**/*.key)",
        "Read(**/key_*)",
        "Read(id_rsa)",
        "Read(id_ed25519)",
        "Bash(cdk deploy:*)",
        "Bash(git reset:*)",
        "Bash(gh repo create:*)",
        "Bash(gh repo delete:*)",
        "Bash(gh issue delete:*)",
        "Bash(gh pr merge:*)",
        "Bash(gh pr close:*)",
        "Bash(gh release create:*)",
        "Bash(gh release delete:*)",
        "Bash(gh alias set:*)",
        "Bash(gh alias delete:*)",
        "Bash(gh api POST:*)",
        "Bash(gh api PUT:*)",
        "Bash(gh api PATCH:*)",
        "Bash(gh api DELETE:*)"
      ],
      "defaultMode": "acceptEdits"
    }
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify_discord.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify_discord.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status_line.sh"
  },
  "skipDangerousModePermissionPrompt": true
}
