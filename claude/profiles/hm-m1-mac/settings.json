{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoMode": {
    "environment": ["$defaults"]
  },
  "defaultMode": "acceptEdits",
  "enabledPlugins": {
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-fable-5[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-5[1m]",
    "ANTHROPIC_MODEL": "opusplan"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "terminal-notifier -title '🍤 Claude Code' -message \"実行中の claude が許可を要求しています.\"$'\\n'\"$USER@$(hostname) $(pwd)\" -sound Glass",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && mise tasks ls 2>/dev/null | grep -q '^format' && mise run format >/dev/null 2>&1 || true",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|NotebookEdit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "terminal-notifier -title '🍤 Claude Code' -message \"実行中の claude が停止しました.\"$'\\n'\"$USER@$(hostname) $(pwd)\" -sound Glass",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "mcpServers": {
    "second-brain": {
      "args": ["-m", "server.mcp_stdio"],
      "command": "/Users/suzukikenichi/programs/second-brain/.venv/bin/python",
      "cwd": "/Users/suzukikenichi/programs/second-brain"
    }
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(gh auth status)",
      "Bash(gh extension list)",
      "Bash(gh run list)",
      "Bash(gh run view:*)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Read(.env)",
      "Read(**/*token*)",
      "Read(**/secrets/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(cdk deploy:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh alias delete:*)",
      "Bash(gh api DELETE:*)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/dotfiles/claude/status_line.sh",
    "type": "command"
  }
}
