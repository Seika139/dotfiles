!.vscode/settings.json

.env
bash/daily/.cache/

.rumdl_cache/

# Python bytecode cache.
__pycache__/
*.pyc
/.pytest_cache/
/.ruff_cache/
/.venv/

# Node dependencies.
/node_modules/
